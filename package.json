{
  "name": "haven-space",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "xampp:apache": "php scripts/start-apache.php",
    "xampp:mysql": "php scripts/start-mysql.php",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint client/js/**/*.js --no-error-on-unmatched-pattern",
    "lint:fix": "eslint client/js/**/*.js --fix --no-error-on-unmatched-pattern",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,scss,md,json,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "4.2.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8"
  }
}
