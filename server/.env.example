# Haven Space - Environment Configuration
# Copy this file to .env and fill in your values

# Application Environment
# Options: local (development), production
APP_ENV=local

# Application Debug Mode
# local: true (detailed error messages)
# production: false (generic error messages for security)
APP_DEBUG=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Database Configuration
# Local (XAMPP): DB_HOST=127.0.0.1, DB_USER=root, DB_PASS=
# Production (Aiven): Use your Aiven database credentials
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=havenspace_db
DB_USER=root
DB_PASS=

# Database SSL Configuration (for cloud providers like Aiven)
# Leave empty for local development
# DB_SSL_MODE=REQUIRED
# DB_SSL_CA=/path/to/ca.pem

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local: http://localhost:8000/api/auth/google/callback.php
# Production: https://yourdomain.com/api/auth/google/callback.php
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback.php

# CORS Configuration (allowed frontend origins, comma-separated)
# Local: http://localhost:3000,http://localhost:8000
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
