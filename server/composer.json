{
  "name": "havenspace/server",
  "description": "Haven Space Boarding House Platform - Backend API",
  "type": "project",
  "license": "MIT",
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.0",
    "guzzlehttp/guzzle": "^7.0",
    "firebase/php-jwt": "^7.0"
  },
  "require-dev": {
    "phpstan/phpstan": "1.10",
    "phpunit/phpunit": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyse",
    "migrate": "php database/migrate.php",
    "server:dev": "php -S localhost:8000 -t api"
  }
}
